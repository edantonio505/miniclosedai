# Custom Ollama image with three small-but-strong models baked in at
# build time. End-users get working models on `docker compose up` with
# zero network dependency at runtime.
#
# Models baked (~5.5 GB total):
#   - llama3.2:3b   — Meta, general-purpose workhorse, supports `think`
#   - qwen2.5:3b    — Alibaba, strong JSON / structured output
#   - gemma2:2b     — Google, snap-fast classifier (~30% faster first-token)
#
# To change the shortlist: edit the RUN bake-models.sh lines below. Each
# model is its own layer — swapping one model doesn't redownload the others.
#
# Build requirements:
#   - Outbound network to registry.ollama.ai (build-time only)
#   - ~15 GB free on Docker's data-root
#   - No GPU needed for build (pulls are pure downloads)

# Pin a concrete Ollama version for reproducible builds. Bump periodically
# to pick up daemon improvements. Without a pin, `:latest` silently triggers
# full re-bakes when the base updates.
FROM ollama/ollama:0.5.13

# Note: no `ENTRYPOINT []` reset here. Docker's ENTRYPOINT only affects
# runtime — RUN commands already execute via `/bin/sh -c`, so there's
# nothing to suppress. Earlier drafts had the reset and a "restore" at the
# end, which triggered the MultipleInstructionsDisallowed warning for
# zero benefit.

# The bake script lives in its own layer so model-list edits don't
# invalidate it. The script uses `ollama list` as its readiness probe
# because the base image ships without curl/wget.
COPY scripts/bake-models.sh /usr/local/bin/bake-models.sh
RUN chmod +x /usr/local/bin/bake-models.sh

# One model per RUN = one layer per model. Critical for caching: editing the
# shortlist below (e.g. swap gemma2:2b for phi3:mini) only reruns the changed
# layer, saving ~30 min of redownload on every iteration.
RUN /usr/local/bin/bake-models.sh llama3.2:3b
RUN /usr/local/bin/bake-models.sh qwen2.5:3b
RUN /usr/local/bin/bake-models.sh gemma2:2b

# Healthcheck: `ollama list` is cheap and verifies both that the daemon is
# up AND that the manifest store is readable. `start_period` gives the
# daemon time to settle after container start (ssh keygen happens once).
HEALTHCHECK --interval=15s --timeout=5s --start-period=90s --retries=5 \
  CMD ollama list > /dev/null 2>&1 || exit 1

# Base image already sets ENTRYPOINT ["/bin/ollama"] + CMD ["serve"] +
# EXPOSE 11434, so we inherit those without redeclaring.
